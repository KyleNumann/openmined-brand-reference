---
interface Props {
  id?: string;
  labelLeft?: string;
  labelRight?: string;
}

const {
  id = 'diamond-embed-1',
  labelLeft = 'Non-Public Data',
  labelRight = 'Attributable Insights',
} = Astro.props;
---

<div id={id} data-label-left={labelLeft} data-label-right={labelRight}></div>

<script is:inline>
(function(){
  /* Skip library init if already loaded — just boot this instance */
  if (window.DiamondEmbed) { boot(); return; }

  var _count = 0, _fontInjected = false;
  var DESIGN_W = 760;
  var DESIGN_H = 620;

  function ensureFont() {
    if (_fontInjected) return; _fontInjected = true;
    if (document.querySelector('link[href*="Sometype+Mono"]')) return;
    var a = document.createElement('link'); a.rel = 'preconnect'; a.href = 'https://fonts.googleapis.com'; document.head.appendChild(a);
    var b = document.createElement('link'); b.rel = 'preconnect'; b.href = 'https://fonts.gstatic.com'; b.crossOrigin = ''; document.head.appendChild(b);
    var c = document.createElement('link'); c.rel = 'stylesheet'; c.href = 'https://fonts.googleapis.com/css2?family=Sometype+Mono:wght@400;500&display=swap'; document.head.appendChild(c);
  }

  function hexToGL(hex) {
    return [
      parseInt(hex.slice(1,3), 16) / 255,
      parseInt(hex.slice(3,5), 16) / 255,
      parseInt(hex.slice(5,7), 16) / 255
    ];
  }

  function prepareGradient(colors, wrap) {
    var n = colors.length;
    if (!n) return { colors: [[1,1,1]], stops: [0.5], count: 1 };
    var total = colors.reduce(function(s, c) { return s + c.weight; }, 0) || 1;
    var outC = [], outS = [];
    if (wrap) {
      var cum = 0;
      for (var i = 0; i < n && i < 9; i++) {
        outC.push(hexToGL(colors[i].hex)); outS.push(cum / total); cum += colors[i].weight;
      }
      outC.push(hexToGL(colors[0].hex)); outS.push(1.0);
    } else {
      var raw = [], cum = 0;
      for (var i = 0; i < n && i < 10; i++) { raw.push(cum + colors[i].weight / 2); cum += colors[i].weight; }
      var first = raw[0], last = raw[raw.length - 1], range = last - first || 1;
      for (var i = 0; i < raw.length; i++) {
        outC.push(hexToGL(colors[i].hex)); outS.push((raw[i] - first) / range);
      }
    }
    return { colors: outC, stops: outS, count: outC.length };
  }

  var VS = [
    'attribute vec2 aPos;',
    'varying vec2 vUV;',
    'void main(){ vUV = aPos * 0.5 + 0.5; gl_Position = vec4(aPos, 0.0, 1.0); }'
  ].join('\n');

  var FS = [
    'precision highp float;',
    'varying vec2 vUV;',
    'uniform float uTime;',
    'uniform vec2  uRes;',
    'uniform vec2  uMouse;',
    'uniform vec3  uGC[10];',
    'uniform float uGS[10];',
    'uniform float uGN;',
    'uniform float uClusters, uWrap;',
    'uniform float uAlongFlow, uAcrossFlow, uRadial;',
    'uniform float uFlowSpeed, uFlowAngle;',
    'uniform float uColorNoise;',
    'uniform float uSize, uRoundness;',
    'uniform float uSoftness, uNoiseAmp, uNoiseScale, uNoiseSpeed, uAmbient;',
    'uniform float uAlphaPow, uOpacity, uSaturation, uTurbulence;',
    'uniform float uAttract, uRipple;',
    'vec3 mod289v3(vec3 x){ return x - floor(x*(1.0/289.0))*289.0; }',
    'vec2 mod289v2(vec2 x){ return x - floor(x*(1.0/289.0))*289.0; }',
    'vec3 permute(vec3 x){ return mod289v3(((x*34.0)+10.0)*x); }',
    'float snoise(vec2 v){',
    '  const vec4 C = vec4(0.211324865405187,0.366025403784439,-0.577350269189626,0.024390243902439);',
    '  vec2 i  = floor(v + dot(v, C.yy));',
    '  vec2 x0 = v - i + dot(i, C.xx);',
    '  vec2 i1 = (x0.x > x0.y) ? vec2(1.0,0.0) : vec2(0.0,1.0);',
    '  vec4 x12 = x0.xyxy + C.xxzz; x12.xy -= i1;',
    '  i = mod289v2(i);',
    '  vec3 p = permute(permute(i.y + vec3(0.0,i1.y,1.0)) + i.x + vec3(0.0,i1.x,1.0));',
    '  vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy), dot(x12.zw,x12.zw)), 0.0);',
    '  m = m*m; m = m*m;',
    '  vec3 x  = 2.0*fract(p*C.www) - 1.0;',
    '  vec3 h  = abs(x) - 0.5;',
    '  vec3 ox = floor(x + 0.5);',
    '  vec3 a0 = x - ox;',
    '  m *= 1.79284291400159 - 0.85373472095314*(a0*a0 + h*h);',
    '  vec3 g; g.x = a0.x*x0.x + h.x*x0.y; g.yz = a0.yz*x12.xz + h.yz*x12.yw;',
    '  return 130.0 * dot(m, g);',
    '}',
    'vec3 sampleGrad(float t){',
    '  t = uWrap > 0.5 ? fract(t) : clamp(t, 0.0, 1.0);',
    '  vec3 c = uGC[0]; float pS = uGS[0];',
    '  for(int i = 1; i < 10; i++){',
    '    if(float(i) >= uGN) break;',
    '    float s = uGS[i];',
    '    float f = clamp((t - pS) / max(s - pS, 0.001), 0.0, 1.0);',
    '    c = mix(c, uGC[i], f * step(pS, t));',
    '    pS = s;',
    '  }',
    '  return c;',
    '}',
    'void main(){',
    '  float aspect = uRes.x / uRes.y;',
    '  float cx = (vUV.x - 0.5) * aspect;',
    '  float cy =  vUV.y - 0.5;',
    '  float s707 = 0.7071067811865476;',
    '  float rx = cx*s707 + cy*s707;',
    '  float ry = cy*s707 - cx*s707;',
    '  float halfSide = uSize * s707;',
    '  float r  = uRoundness * halfSide;',
    '  vec2  q  = abs(vec2(rx, ry)) - (halfSide - r);',
    '  float d  = length(max(q, 0.0)) + min(max(q.x, q.y), 0.0) - r;',
    '  float len = length(vec2(cx, cy));',
    '  float ns = uNoiseScale, nsp = uNoiseSpeed;',
    '  float edgeN = snoise(vec2(cx*ns      + uTime*nsp*0.3, cy*ns      - uTime*nsp*0.2)) * uNoiseAmp',
    '              + snoise(vec2(cx*ns*2.1  + 5.0 - uTime*nsp*0.4, cy*ns*2.1  + uTime*nsp*0.3)) * uNoiseAmp*0.5',
    '              + snoise(vec2(cx*ns*4.3  +10.0 + uTime*nsp*0.2, cy*ns*4.3  - uTime*nsp*0.5)) * uNoiseAmp*0.25;',
    '  float mx = (uMouse.x - 0.5) * aspect;',
    '  float my =  uMouse.y - 0.5;',
    '  float mDistSq = (cx-mx)*(cx-mx) + (cy-my)*(cy-my);',
    '  float ripple  = uRipple  * exp(-mDistSq/0.02) * snoise(vec2(cx*10.0 - uTime*0.4, cy*10.0));',
    '  float attract = uAttract * exp(-mDistSq/0.06);',
    '  float ambient = (snoise(vec2(cx*8.0  - uTime*0.30, cy*6.0  + uTime*0.15))*0.005',
    '                 + snoise(vec2(cx*12.0 + uTime*0.20, cy*10.0 - uTime*0.10))*0.003) * uAmbient;',
    '  float dMod   = d - edgeN - ripple - attract - ambient;',
    '  float outside = max(dMod, 0.0);',
    '  float soft2   = 2.0 * uSoftness * uSoftness;',
    '  float alpha   = exp(-(outside*outside) / max(soft2, 1e-8));',
    '  float aN = snoise(vec2(cx*5.0 + uTime*0.03, cy*5.0 - uTime*0.02)) * 0.08;',
    '  alpha = clamp(alpha + aN*alpha, 0.0, 1.0);',
    '  alpha = pow(max(alpha, 1e-6), uAlphaPow);',
    '  alpha *= smoothstep(0.0, 0.03, alpha);',
    '  float flow   = uTime * uFlowSpeed;',
    '  float angRad = uFlowAngle * 3.14159265 / 180.0;',
    '  float fdx = cos(angRad), fdy = sin(angRad);',
    '  float halfSize = max(uSize, 0.01);',
    '  float tAlong  = (cx*fdx  + cy*fdy)  / (halfSize*2.0) + 0.5;',
    '  float tAcross = (-cx*fdy + cy*fdx)  / (halfSize*2.0) + 0.5;',
    '  float tRadial = len / halfSize;',
    '  float cNoise  = snoise(vec2(cx*3.0 - flow*2.0 + 20.0, cy*4.0 - uTime*0.04)) * uColorNoise;',
    '  float turbN   = snoise(vec2(cx*4.0 - uTime*0.1, cy*4.0 + uTime*0.08)) * uTurbulence * 0.3;',
    '  float gradT   = (tAlong*uAlongFlow + tAcross*uAcrossFlow + tRadial*uRadial + cNoise + turbN) * uClusters + flow;',
    '  vec3 color = sampleGrad(gradT);',
    '  float lum  = dot(color, vec3(0.299, 0.587, 0.114));',
    '  color = mix(vec3(lum), color, uSaturation);',
    '  gl_FragColor = vec4(color * (alpha * uOpacity), alpha * uOpacity);',
    '}'
  ].join('\n');

  function compileShader(gl, type, src) {
    var s = gl.createShader(type);
    gl.shaderSource(s, src); gl.compileShader(s);
    if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) {
      console.error('DiamondEmbed shader error:', gl.getShaderInfoLog(s)); return null;
    }
    return s;
  }

  function DiamondEmbed(container, config) {
    this._id  = 'de' + (++_count);
    this._el  = typeof container === 'string' ? document.querySelector(container) : container;
    if (!this._el) throw new Error('DiamondEmbed: container not found — ' + container);

    var defaults = {
      labelLeft:   'Label Left',
      labelRight:  'Label Right',
      aspectRatio: DESIGN_W / DESIGN_H,
      cropTop:     0,
      cropBottom:  0,
      cropLeft:    0,
      cropRight:   0,
      theme:  { dark: '#353243', mid: '#353243', bg: 'transparent', darkModeColor: '#fcfcfd' },
      colors: DiamondEmbed.DEFAULT_COLORS,
      shader: DiamondEmbed.DEFAULT_SHADER
    };
    this._cfg = Object.assign({}, defaults, config || {});
    if (config && config.theme)  this._cfg.theme  = Object.assign({}, defaults.theme,  config.theme);
    if (config && config.shader) this._cfg.shader = Object.assign({}, defaults.shader, config.shader);

    this._tRX = 0; this._tRY = 0;
    this._cRX = 0; this._cRY = 0;
    this._mux = 0.5; this._muy = 0.5;
    this._smux = 0.5; this._smuy = 0.5;
    this._scale = 1;
    this._gl = null; this._glU = null;
    this._rafId = null; this._destroyed = false;

    ensureFont();
    this._injectStyles();
    this._buildDOM();
    this._initWebGL();
    this._bindEvents();
    this._initResize();
    this._start();
  }

  DiamondEmbed.prototype._injectStyles = function() {
    var id = this._id, t = this._cfg.theme, sid = 'de-style-' + id;
    if (document.getElementById(sid)) return;

    var css = [
      '.'+id+' { position: relative; width: 100%; overflow: hidden; background: ' + t.bg + '; }',
      '.'+id+' .de-stage { position: absolute; width: ' + DESIGN_W + 'px; height: ' + DESIGN_H + 'px; top: 50%; left: 50%; transform-origin: center center; will-change: transform; }',
      '.'+id+' .de-webgl { position: absolute; width: ' + DESIGN_W + 'px; height: ' + DESIGN_H + 'px; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 5; pointer-events: none; background: transparent; }',
      '.'+id+' .de-origin { position: absolute; top: 50%; left: 50%; width: 0; height: 0; z-index: 11; }',
      '.'+id+' .de-group-left  { position: absolute; top: 50%; left: 50%; z-index: 1; }',
      '.'+id+' .de-group-right { position: absolute; top: 50%; left: 50%; z-index: 10; }',
      '.'+id+' .de-outline { position: absolute; width: 340px; height: 340px; border: 1.44px solid ' + t.dark + '; transform: translate(-50%,-50%) rotate(45deg); }',
      '.'+id+' .de-outline--left  { left: -120px; top: 0; z-index: 0; background: transparent; }',
      '.'+id+' .de-outline--right { left:  120px; top: 0; z-index: 10; background: transparent; }',
      '.'+id+' .de-label { position: absolute; top: 0; font-family: "Sometype Mono", monospace; font-weight: 500; font-size: 18px; line-height: 23px; color: ' + t.mid + '; white-space: nowrap; opacity: 0; transition: opacity 1s ease, transform 1s ease; z-index: 11; }',
      '.'+id+' .de-label--left  { left: -335px;  transform: translateY(-50%) translateX(-12px); }',
      '.'+id+' .de-label--right { right: -335px; transform: translateY(-50%) translateX(12px); text-align: right; }',
      '.'+id+' .de-label.de-visible           { opacity: 1; }',
      '.'+id+' .de-label--left.de-visible     { transform: translateY(-50%) translateX(0); }',
      '.'+id+' .de-label--right.de-visible    { transform: translateY(-50%) translateX(0); }',
      /* CHANGED: was body.dark-theme — now uses html[data-theme="dark"] per Astro build */
      'html[data-theme="dark"] .'+id+' .de-outline { border-color: ' + t.darkModeColor + '; }',
      'html[data-theme="dark"] .'+id+' .de-label   { color: '        + t.darkModeColor + '; }',
    ].join('\n');

    var el = document.createElement('style');
    el.id = sid; el.textContent = css;
    document.head.appendChild(el);
  };

  DiamondEmbed.prototype._buildDOM = function() {
    this._el.classList.add(this._id);
    var div = document.createElement('div');
    div.innerHTML = [
      '<div class="de-stage">',
      '  <canvas class="de-webgl" width="' + DESIGN_W + '" height="' + DESIGN_H + '"></canvas>',
      '  <div class="de-group-left"><div class="de-outline de-outline--left"></div></div>',
      '  <div class="de-group-right"><div class="de-outline de-outline--right"></div></div>',
      '  <div class="de-origin">',
      '    <span class="de-label de-label--left">'  + this._cfg.labelLeft  + '</span>',
      '    <span class="de-label de-label--right">' + this._cfg.labelRight + '</span>',
      '  </div>',
      '</div>',
    ].join('');
    while (div.firstChild) this._el.appendChild(div.firstChild);

    this._stage      = this._el.querySelector('.de-stage');
    this._groupLeft  = this._el.querySelector('.de-group-left');
    this._groupRight = this._el.querySelector('.de-group-right');
    this._webglEl    = this._el.querySelector('.de-webgl');
    this._lblLeft    = this._el.querySelector('.de-label--left');
    this._lblRight   = this._el.querySelector('.de-label--right');
  };

  DiamondEmbed.prototype._initWebGL = function() {
    var canvas = this._webglEl;
    var gl = canvas.getContext('webgl', { antialias: true, alpha: true, premultipliedAlpha: true });
    if (!gl) { console.warn('DiamondEmbed: WebGL not available'); return; }
    this._gl = gl;

    var vs = compileShader(gl, gl.VERTEX_SHADER, VS);
    var fs = compileShader(gl, gl.FRAGMENT_SHADER, FS);
    if (!vs || !fs) return;

    var prog = gl.createProgram();
    gl.attachShader(prog, vs); gl.attachShader(prog, fs); gl.linkProgram(prog);
    if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) {
      console.error('DiamondEmbed link error:', gl.getProgramInfoLog(prog)); return;
    }
    gl.useProgram(prog);

    var buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW);
    var aPos = gl.getAttribLocation(prog, 'aPos');
    gl.enableVertexAttribArray(aPos);
    gl.vertexAttribPointer(aPos, 2, gl.FLOAT, false, 0, 0);

    gl.enable(gl.BLEND);
    gl.blendFunc(gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);
    gl.viewport(0, 0, canvas.width, canvas.height);

    var u = {};
    ['uTime','uRes','uMouse','uGN','uClusters','uWrap',
     'uAlongFlow','uAcrossFlow','uRadial',
     'uFlowSpeed','uFlowAngle','uColorNoise',
     'uSize','uRoundness',
     'uSoftness','uNoiseAmp','uNoiseScale','uNoiseSpeed','uAmbient',
     'uAlphaPow','uOpacity','uSaturation','uTurbulence',
     'uAttract','uRipple'].forEach(function(n) {
      u[n] = gl.getUniformLocation(prog, n);
    });
    for (var i = 0; i < 10; i++) {
      u['uGC' + i] = gl.getUniformLocation(prog, 'uGC[' + i + ']');
      u['uGS' + i] = gl.getUniformLocation(prog, 'uGS[' + i + ']');
    }
    this._glU = u;
  };

  DiamondEmbed.prototype._applyAspect = function() {
    var visX = 1 - this._cfg.cropLeft - this._cfg.cropRight;
    var visY = 1 - this._cfg.cropTop  - this._cfg.cropBottom;
    var ar = this._cfg.aspectRatio * Math.max(visX, 0.01) / Math.max(visY, 0.01);
    this._el.style.aspectRatio = ar;
  };

  DiamondEmbed.prototype._initResize = function() {
    var self = this;
    function applyScale() {
      var w = self._el.offsetWidth;
      if (!w) return;
      self._scale = w / DESIGN_W;
      var xShift = (self._cfg.cropRight - self._cfg.cropLeft) / 2 * DESIGN_W * self._scale;
      var yShift = (self._cfg.cropBottom - self._cfg.cropTop) / 2 * DESIGN_H * self._scale;
      self._stage.style.transform =
        'translate(calc(-50% + ' + xShift + 'px), calc(-50% + ' + yShift + 'px)) scale(' + self._scale + ')';
    }
    self._applyScale = applyScale;
    self._applyAspect();
    applyScale();
    if (window.ResizeObserver) {
      this._ro = new ResizeObserver(applyScale);
      this._ro.observe(this._el);
    } else {
      this._resizeFn = applyScale;
      window.addEventListener('resize', applyScale);
    }
  };

  DiamondEmbed.prototype._bindEvents = function() {
    var self = this;
    this._onMove = function(e) {
      if (self._destroyed) return;
      var vCX = window.innerWidth  / 2;
      var vCY = window.innerHeight / 2;
      self._tRX = ((e.clientY - vCY) / vCY) * 5;
      self._tRY = ((e.clientX - vCX) / vCX) * 5;
      var r = self._el.getBoundingClientRect();
      self._mux = (e.clientX - r.left) / r.width;
      self._muy = 1.0 - (e.clientY - r.top)  / r.height;
    };
    this._onLeave = function() {
      if (!self._destroyed) { self._mux = 0.5; self._muy = 0.5; }
    };
    document.addEventListener('mousemove', this._onMove, { passive: true });
    this._el.addEventListener('mouseleave', this._onLeave, { passive: true });
  };

  DiamondEmbed.prototype._start = function() {
    var self = this;
    self._visible = true;
    self._elapsed = 0;
    self._lastTs  = null;

    if (window.IntersectionObserver) {
      self._io = new IntersectionObserver(function(entries) {
        self._visible = entries[0].isIntersecting;
        if (self._visible && !self._rafId) {
          self._lastTs = null;
          self._rafId  = requestAnimationFrame(loop);
        }
      }, { threshold: 0 });
      self._io.observe(self._el);
    }

    self._onVisibility = function() {
      if (document.hidden) {
        self._visible = false;
      } else {
        self._visible = true;
        if (!self._rafId && !self._destroyed) {
          self._lastTs = null;
          self._rafId  = requestAnimationFrame(loop);
        }
      }
    };
    document.addEventListener('visibilitychange', self._onVisibility);

    setTimeout(function() { if (!self._destroyed) self._lblLeft.classList.add('de-visible');  }, 500);
    setTimeout(function() { if (!self._destroyed) self._lblRight.classList.add('de-visible'); }, 800);

    function loop(ts) {
      if (self._destroyed) return;
      if (!self._visible || document.hidden) { self._rafId = null; return; }
      if (self._lastTs !== null) self._elapsed += (ts - self._lastTs) / 1000.0;
      self._lastTs = ts;
      var t = self._elapsed;
      var gl = self._gl, u = self._glU, cfg = self._cfg;

      self._smux += (self._mux - self._smux) * 0.08;
      self._smuy += (self._muy - self._smuy) * 0.08;

      if (gl && u) {
        gl.clearColor(0, 0, 0, 0);
        gl.clear(gl.COLOR_BUFFER_BIT);
        gl.uniform1f(u.uTime,  t);
        gl.uniform2f(u.uRes,   self._webglEl.width, self._webglEl.height);
        gl.uniform2f(u.uMouse, self._smux, self._smuy);

        var g = prepareGradient(cfg.colors, cfg.shader.wrap);
        gl.uniform1f(u.uGN, g.count);
        for (var i = 0; i < 10; i++) {
          if (i < g.count) {
            gl.uniform3fv(u['uGC' + i], g.colors[i]);
            gl.uniform1f(u['uGS' + i], g.stops[i]);
          }
        }

        var s = cfg.shader;
        gl.uniform1f(u.uClusters,  s.clusters);
        gl.uniform1f(u.uWrap,      s.wrap ? 1 : 0);
        gl.uniform1f(u.uAlongFlow, s.alongFlow);
        gl.uniform1f(u.uAcrossFlow,s.acrossFlow);
        gl.uniform1f(u.uRadial,    s.radial);
        gl.uniform1f(u.uFlowSpeed, s.flowSpeed);
        gl.uniform1f(u.uFlowAngle, s.flowAngle);
        gl.uniform1f(u.uColorNoise,s.colorNoise);
        gl.uniform1f(u.uSize,      s.size);
        gl.uniform1f(u.uRoundness, s.roundness);
        gl.uniform1f(u.uSoftness,  s.softness);
        gl.uniform1f(u.uNoiseAmp,  s.noiseAmp);
        gl.uniform1f(u.uNoiseScale,s.noiseScale);
        gl.uniform1f(u.uNoiseSpeed,s.noiseSpeed);
        gl.uniform1f(u.uAmbient,   s.ambient);
        gl.uniform1f(u.uAlphaPow,  s.alphaPow);
        gl.uniform1f(u.uOpacity,   s.opacity);
        gl.uniform1f(u.uSaturation,s.saturation);
        gl.uniform1f(u.uTurbulence,s.turbulence);
        gl.uniform1f(u.uAttract,   s.attract);
        gl.uniform1f(u.uRipple,    s.ripple);
        gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
      }

      self._cRX += (self._tRX - self._cRX) * 0.03;
      self._cRY += (self._tRY - self._cRY) * 0.03;
      var breathe = Math.sin(t * 0.7);
      var sc      = 1 + Math.sin(t * 0.5) * 0.008;

      var tform =
        'perspective(1000px)' +
        ' rotateX(' + (self._cRX + breathe * 0.15) + 'deg)' +
        ' rotateY(' + self._cRY + 'deg)' +
        ' scale(' + sc + ')';

      self._groupLeft.style.transform  = tform;
      self._groupRight.style.transform = tform;

      self._rafId = requestAnimationFrame(loop);
    }

    this._rafId = requestAnimationFrame(loop);
  };

  DiamondEmbed.prototype.destroy = function() {
    this._destroyed = true;
    if (this._rafId) cancelAnimationFrame(this._rafId);
    if (this._io) this._io.disconnect();
    if (this._ro) this._ro.disconnect();
    if (this._resizeFn) window.removeEventListener('resize', this._resizeFn);
    if (this._onVisibility) document.removeEventListener('visibilitychange', this._onVisibility);
    document.removeEventListener('mousemove', this._onMove);
    this._el.removeEventListener('mouseleave', this._onLeave);
    var s = document.getElementById('de-style-' + this._id); if (s) s.remove();
    this._el.classList.remove(this._id);
    var stage = this._el.querySelector('.de-stage'); if (stage) stage.remove();
  };

  DiamondEmbed.DEFAULT_COLORS = [
    { hex: '#F8C073', weight: 1   },
    { hex: '#F79763', weight: 1   },
    { hex: '#CC677B', weight: 1   },
    { hex: '#937098', weight: 1   },
    { hex: '#6976ae', weight: 1   },
    { hex: '#52a8c5', weight: 1   },
    { hex: '#53bea9', weight: 1   },
    { hex: '#96d195', weight: 0.8 },
    { hex: '#f2d98c', weight: 1   },
  ];

  DiamondEmbed.DEFAULT_SHADER = {
    clusters:   1,     wrap:       true,
    alongFlow:  0.43,  acrossFlow: 0.25,  radial:    0,
    colorNoise: 0,     flowSpeed:  0.06,  flowAngle: 332,
    size:       0.4,   roundness:  0.15,
    softness:   0.04,  noiseAmp:   0.025, noiseScale: 3.0,
    noiseSpeed: 0.3,   ambient:    0.5,
    alphaPow:   2.0,   opacity:    1.0,
    saturation: 1.08,  turbulence: 0.33,
    attract:    0.013, ripple:     0.019,
  };

  window.DiamondEmbed = DiamondEmbed;
  boot();

  function boot() {
    /* Read config from data attributes on the container element */
    var el = document.querySelector('[data-label-left][data-label-right]');
    var labelLeft  = (el && el.getAttribute('data-label-left'))  || 'Non-Public Data';
    var labelRight = (el && el.getAttribute('data-label-right')) || 'Attributable Insights';
    /* Use the element's id, falling back to the default */
    var containerId = (el && '#' + el.id) || '#diamond-embed-1';

    new DiamondEmbed(containerId, {
      labelLeft:   labelLeft,
      labelRight:  labelRight,
      aspectRatio: 1.225,
      cropTop:     0.148,
      cropBottom:  0.133,
      cropLeft:    0.134,
      cropRight:   0.140,
      theme: {
        dark:          '#353243',
        mid:           '#353243',
        bg:            'transparent',
        darkModeColor: '#fcfcfd',
      },
    });
  }

})();
</script>
