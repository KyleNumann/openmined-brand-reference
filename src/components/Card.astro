---
interface Props {
  variant?: 'blog' | 'feature' | 'partner';
  href?: string;
  title?: string;
  date?: string;
  category?: string;
  image?: string;
  imageAlt?: string;
  class?: string;
}

const {
  variant = 'blog',
  href = '#',
  title = 'Placeholder Article Title Goes Here',
  date = 'May 27, 2026',
  category = 'Research',
  image,
  imageAlt = '',
  class: className = '',
} = Astro.props;
---

{variant === 'blog' && (
  <article class={['card', 'card--blog', className].filter(Boolean).join(' ')}>
    {image && (
      <div class="card__image-wrap">
        <img src={image} alt={imageAlt} class="card__image" loading="lazy" />
      </div>
    )}
    {!image && (
      <div class="card__image-wrap card__image-placeholder">
        <span>Image placeholder</span>
      </div>
    )}
    <div class="card__body">
      <div class="card__meta">
        <time>{date}</time>
        <span class="card__separator">·</span>
        <span class="card__category">{category}</span>
      </div>
      <h4 class="card__title">{title}</h4>
    </div>
    <a href={href} class="absolute-link" aria-label={title}></a>
  </article>
)}

{variant === 'feature' && (
  <div class={['card', 'card--feature', className].filter(Boolean).join(' ')}>
    <div class="card__icon">
      <slot name="icon">
        <div class="card__icon-placeholder"></div>
      </slot>
    </div>
    <div class="card__body">
      <h4 class="card__title">{title}</h4>
      <slot />
    </div>
  </div>
)}

{variant === 'partner' && (
  <div class={['card', 'card--partner', className].filter(Boolean).join(' ')}>
    <slot>
      <div class="card__logo-placeholder">Logo</div>
    </slot>
  </div>
)}

<style>
  .card {
    position: relative;
  }

  /* Blog card */
  .card--blog {
    background-color: var(--surface-background-bright);
    border-radius: var(--border-radius-S);
    overflow: hidden;
  }

  .card__image-wrap {
    border-radius: var(--border-radius-S);
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .card__image-placeholder {
    background-color: var(--surface-foreground-low);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-subtle);
    font-size: 14px;
  }

  .card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--border-radius-S);
  }

  .card__body {
    padding: var(--spacing-L) 0;
  }

  .card__meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-S);
    font-size: 14px;
    color: var(--text-subtle);
    margin-bottom: var(--spacing-S);
  }

  .card__separator { opacity: 0.5; }

  .card__category {
    font-weight: 500;
    color: var(--text-body);
  }

  .card__title {
    font-family: 'Rubik', serif;
    font-size: 22px;
    font-weight: 400;
    line-height: 1.3;
    color: var(--text-headline);
  }

  /* Feature card */
  .card--feature {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-L);
  }

  .card__icon-placeholder {
    width: 48px;
    height: 48px;
    background: var(--gradient-teal-green);
    border-radius: var(--border-radius-S);
  }

  .card--feature .card__body h4 {
    margin-bottom: var(--spacing-L);
  }

  .card--feature .card__body :global(p) {
    margin-bottom: var(--spacing-L);
    color: var(--text-body);
  }

  .card--feature .card__body :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Partner card */
  .card--partner {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-L);
  }

  .card__logo-placeholder {
    width: 120px;
    height: 48px;
    background-color: var(--surface-foreground-low);
    border-radius: var(--border-radius-XS);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-subtle);
    font-size: 12px;
  }
</style>
