---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<blockquote class={['bq', className].filter(Boolean).join(' ')}>
  <slot />
</blockquote>

<style>
  .bq {
    border-left: 1px solid var(--border-color);
    padding-left: var(--spacing-L);
    margin-block: var(--spacing-L) var(--spacing-3XL);
  }
</style>
